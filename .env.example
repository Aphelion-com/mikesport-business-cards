# ─────────────────────────────────────────────────────────────
# Mike Sport Digital Business Cards — Environment Variables
# Copy this file to ".env" and fill in real values before deploying.
# ─────────────────────────────────────────────────────────────

# --- PostgreSQL (used by the "db" service in docker-compose) ---
POSTGRES_DB=mikesport_cards
POSTGRES_USER=mikesport
POSTGRES_PASSWORD=change_me_strong_password

# --- Database connection string used by the app / Prisma ---
# When running via docker-compose, the host is the service name "db".
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://mikesport:change_me_strong_password@db:5432/mikesport_cards?schema=public

# --- Public base URL (used for card links + QR codes) ---
# No trailing slash. Example: https://cards.mikesport.tech
NEXT_PUBLIC_BASE_URL=https://cards.mikesport.tech

# --- Admin dashboard credentials ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin_password

# --- Secret used to sign the admin session cookie (min 32 chars) ---
# Generate one with: openssl rand -base64 32
AUTH_SECRET=change_me_to_a_long_random_secret_string

# --- Session cookie Secure flag ---
# Keep "false" while testing over plain HTTP (e.g. http://145.223.101.109:3015),
# otherwise browsers drop the cookie and login appears to hang.
# Set to "true" once the app is served over HTTPS (e.g. https://cards.mikesport.tech).
AUTH_COOKIE_SECURE=false
