generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Card {
  id              String   @id @default(cuid())
  fullName        String
  slug            String   @unique
  position        String
  mobilePhone     String
  companyPhone    String?
  extension       String?
  email           String
  website         String?
  address         String?
  profileImageUrl String?
  linkedinUrl     String?
  instagramUrl    String?
  facebookUrl     String?
  tiktokUrl       String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  events CardEvent[]

  @@index([slug])
  @@map("cards")
}

enum CardEventType {
  PAGE_VIEW
  SAVE_CONTACT
  QR_DOWNLOAD
  COPY_URL
  PREVIEW_OPEN
}

model CardEvent {
  id        String        @id @default(cuid())
  cardId    String
  type      CardEventType
  userAgent String?
  referrer  String?
  createdAt DateTime      @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([type])
  @@index([createdAt])
  @@map("card_events")
}
